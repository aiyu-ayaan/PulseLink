{
  "$schema": "https://wails.io/schemas/config.v3.json",
  "version": "3",
  "name": "PulseLink",
  "outputfilename": "pulselink",
  "info": {
    "productName": "PulseLink",
    "description": "Control your Windows PC from your phone",
    "companyName": "PulseLink"
  },
  "frontend": {
    "dir": "apps/desktop/frontend",
